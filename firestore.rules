rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Users collection - users can read all authenticated, write only their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // Teams collection
    match /teams/{teamId} {
      // Anyone authenticated can read teams
      allow read: if request.auth != null;
      
      // Anyone authenticated can create a team
      allow create: if request.auth != null;
      
      // Authenticated users can update (for joining teams, submitting clues)
      allow update: if request.auth != null;
      
      // Only admins can delete
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Game state - everyone can read (even before login), only admins can write
    match /gameState/{document} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    
    // Announcements - everyone can read, only admins can write
    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if request.auth != null && isAdmin();
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Admins collection - only readable by admin themselves, never writable
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Must be created manually in Firebase Console
    }
  }
}

